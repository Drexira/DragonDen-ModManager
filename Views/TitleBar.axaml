<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:DragonDen.ModManager.Views"
             x:Class="DragonDen.ModManager.Views.TitleBar">

    <UserControl.Resources>
        <SolidColorBrush x:Key="Dd.Panel" Color="#13181D" />
        <SolidColorBrush x:Key="Dd.Border" Color="#20262D" />
        <SolidColorBrush x:Key="Dd.Text" Color="#EDEDED" />
        <SolidColorBrush x:Key="Dd.Orange" Color="#FF8A00" />
        <SolidColorBrush x:Key="Dd.Orange.Hover" Color="#FFA333" />
        <SolidColorBrush x:Key="Dd.Red" Color="#CC3A3A" />
        <SolidColorBrush x:Key="Dd.Red.Hover" Color="#E04B4B" />

        <SolidColorBrush x:Key="Dd.Btn" Color="#2e3890" />
        <SolidColorBrush x:Key="Dd.Btn.Hover" Color="#3441BF" />
        <SolidColorBrush x:Key="Dd.Btn.Fg" Color="#EDEDED" />
        <SolidColorBrush x:Key="Dd.Btn.HoverFg" Color="#D9D9D9" />
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button.chrome-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource Dd.Text}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="Height" Value="32" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style Selector="Button.chrome-btn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource Dd.Orange}" />
            <Setter Property="Foreground" Value="#111111" />
        </Style>

        <Style Selector="Button.chrome-btn:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#FFA333" />
            <Setter Property="Foreground" Value="#111111" />
        </Style>

        <Style Selector="Button.chrome-btn.close:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource Dd.Red}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.chrome-btn.close:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource Dd.Red.Hover}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="Button.btn-github">
            <Setter Property="Background" Value="{StaticResource Dd.Orange}" />
            <Setter Property="Foreground" Value="#0C1116" />
        </Style>
        <Style Selector="Button.btn-github:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource Dd.Orange.Hover}" />
        </Style>
        
        <Style Selector="Button.btn">
            <Setter Property="Background" Value="{StaticResource Dd.Btn}" />
            <Setter Property="Foreground" Value="{StaticResource Dd.Btn.Fg}" />
            <Setter Property="BorderBrush" Value="{StaticResource Dd.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="MinWidth" Value="84" />
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.btn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource Dd.Btn.Hover}" />
            <Setter Property="Foreground" Value="{StaticResource Dd.Btn.HoverFg}" />
        </Style>
    </UserControl.Styles>

    <Border x:Name="RootBar"
            Background="{StaticResource Dd.Panel}"
            BorderBrush="{StaticResource Dd.Border}" BorderThickness="0,0,0,1"
            Height="40">
        <Grid ColumnDefinitions="*,Auto,Auto,Auto">

            <Border x:Name="DragArea"
                    Background="Transparent"
                    PointerPressed="OnDragAreaPointerPressed"
                    DoubleTapped="OnDragAreaDoubleTapped">
                <WrapPanel HorizontalAlignment="Left">
                    <Image Source="/Assets/icon.png"
                           Width="35" Height="35"
                           Margin="10,2,6,0"
                           VerticalAlignment="Center"/>
                    <TextBlock Margin="0,3,0,0"
                               VerticalAlignment="Center"
                               FontWeight="DemiBold"
                               Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                               Foreground="{StaticResource Dd.Text}" />
                </WrapPanel>
            </Border>

            <Button Grid.Column="0" x:Name="GithubButton" Content="Report Issues and Feedback Here" FontWeight="Bold" Classes="btn btn-github" Width="250"
                    Click="OnOpenIssuesPage" HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <Button Grid.Column="1" Classes="chrome-btn"
                    IsVisible="{Binding ShowMinimize, RelativeSource={RelativeSource AncestorType=views:TitleBar}}"
                    Click="OnMinimize">
                <TextBlock Text="—" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Button>

            <Button Grid.Column="2" Classes="chrome-btn"
                    IsVisible="{Binding ShowMaximize, RelativeSource={RelativeSource AncestorType=views:TitleBar}}"
                    Click="OnMaxRestore">
                <TextBlock x:Name="MaxIcon" Text="▢" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Button>

            <Button Grid.Column="3" Classes="chrome-btn close" Click="OnClose">
                <TextBlock Text="✕" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Button>
        </Grid>
    </Border>
</UserControl>