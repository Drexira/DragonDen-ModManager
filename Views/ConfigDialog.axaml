<Window
    x:Class="DragonDen.ModManager.Views.ConfigDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
    TransparencyLevelHint="AcrylicBlur,Blur,Transparent"
    Background="{DynamicResource PanelBrush}"
    WindowStartupLocation="CenterOwner"
    SystemDecorations="BorderOnly"
    MinWidth="900" MinHeight="500"
    Width="1000" Height="625"
    SizeToContent="Manual"
    ExtendClientAreaToDecorationsHint="True"
    ExtendClientAreaChromeHints="NoChrome"
    ShowInTaskbar="False"
    CanResize="True">

    <Window.Resources>
        <SolidColorBrush x:Key="Dd.Panel" Color="#13181D" />
        <SolidColorBrush x:Key="Dd.Border" Color="#20262D" />
        <SolidColorBrush x:Key="Dd.Text" Color="#EDEDED" />
        <SolidColorBrush x:Key="Dd.Subtle" Color="#9AA4AE" />
        <SolidColorBrush x:Key="Dd.ListBg" Color="#151A20" />
        <SolidColorBrush x:Key="Dd.ListBr" Color="#232A33" />
        <SolidColorBrush x:Key="Dd.Accent" Color="#FF8A00" />
        <SolidColorBrush x:Key="Dd.TitleHover" Color="#2E2E2E" />
        <SolidColorBrush x:Key="Dd.TitlePress" Color="#3A3A3A" />
    </Window.Resources>

    <Grid RowDefinitions="Auto,*" Background="{StaticResource Dd.Panel}">
        <Border Background="{StaticResource Dd.Panel}" BorderBrush="{StaticResource Dd.Border}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto" Height="36">
                <StackPanel Orientation="Horizontal" Spacing="10" Margin="12,0" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" Text="Config Editor" VerticalAlignment="Center" FontWeight="SemiBold" />
                    <Border Background="#262B31" CornerRadius="8" Padding="8,2" BorderBrush="#333A43" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="Configs" />
                            <TextBlock Text="•" />
                            <TextBlock x:Name="FilesCountText" Text="0" />
                        </StackPanel>
                    </Border>
                    <Border Background="#262B31" CornerRadius="8" Padding="8,2" BorderBrush="#333A43" BorderThickness="1" Margin="6,0,0,0">
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="HintText" Foreground="{StaticResource Dd.Subtle}" FontSize="12" Text="Select a config to edit • ESC closes this window" />
                        </StackPanel>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,6,0" Spacing="6">
                    <Button Width="28" Height="28" Background="Transparent" BorderThickness="0" Click="OnWindowCloseClicked">
                        <Button.Styles>
                            <Style Selector="Button:pointerover">
                                <Setter Property="Background" Value="{StaticResource Dd.TitleHover}" />
                            </Style>
                            <Style Selector="Button:pressed">
                                <Setter Property="Background" Value="{StaticResource Dd.TitlePress}" />
                            </Style>
                        </Button.Styles>
                        <Grid Width="12" Height="12">
                            <Path Data="M1,1 L11,11" Stroke="White" StrokeThickness="1.7" StrokeLineCap="Round" />
                            <Path Data="M11,1 L1,11" Stroke="White" StrokeThickness="1.7" StrokeLineCap="Round" />
                        </Grid>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*,6,0" x:Name="MainSplit" Margin="12">
            <Border x:Name="LeftPanel" Grid.Column="0" Background="{StaticResource Dd.ListBg}" BorderBrush="{StaticResource Dd.ListBr}"
                    BorderThickness="1" CornerRadius="10" Margin="0" MinWidth="0">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <ListBox x:Name="FilesList" SelectionMode="Single" SelectionChanged="OnSelectionChanged" />
                </ScrollViewer>
            </Border>

            <GridSplitter x:Name="ColSplitter" Grid.Column="1" Background="{StaticResource Dd.ListBr}" HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" ShowsPreview="True" ResizeDirection="Columns" Cursor="SizeWestEast"
                          IsVisible="False" ZIndex="2" PointerMoved="OnSplitterPointerMoved" PointerReleased="OnSplitterPointerReleased" />

            <Border x:Name="EditorPanel"
                    Grid.Column="2"
                    Background="{StaticResource Dd.ListBg}"
                    BorderBrush="{StaticResource Dd.ListBr}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Margin="0"
                    MinWidth="0"
                    IsVisible="False">
                <Grid RowDefinitions="Auto,*">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto" Margin="10,10,10,8">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock x:Name="DirtyDot" Text="• Modified" Foreground="{StaticResource Dd.Accent}" IsVisible="False" />
                        </StackPanel>
                        <Button Grid.Column="1" x:Name="SaveBtn" Content="Save" Click="OnSaveClicked" IsEnabled="False" Margin="8,0,0,0" />
                        <Button Grid.Column="2" x:Name="ResetBtn" Content="Reset Changes" Click="OnResetClicked" IsEnabled="False" Margin="8,0,0,0" />
                        <Button Grid.Column="3" Content="Close" Click="OnCloseEditorClicked" Margin="8,0,0,0" />
                    </Grid>

                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <ae:TextEditor x:Name="EditorText" Margin="8" MinWidth="0" MinHeight="0" ShowLineNumbers="True" 
                                       FontFamily="Consolas, Menlo, Monaco, Courier New" FontSize="14" WordWrap="False"
                                       HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                       Background="#0F1317" Foreground="#EDEDED" TextChanged="OnEditorTextChanged" />
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>