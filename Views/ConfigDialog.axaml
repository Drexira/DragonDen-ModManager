<Window
    x:Class="DragonDen.ModManager.Views.ConfigDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
    MinWidth="1000" MinHeight="650"
    MaxWidth="1300" MaxHeight="900"
    SizeToContent="WidthAndHeight"
    TransparencyLevelHint="AcrylicBlur,Blur,Transparent"
    Background="{DynamicResource PanelBrush}"
    SystemDecorations="None"
    ExtendClientAreaToDecorationsHint="True"
    ExtendClientAreaChromeHints="NoChrome"
    ExtendClientAreaTitleBarHeightHint="36"
    WindowStartupLocation="CenterOwner"
    ShowInTaskbar="False"
    CanResize="False">

  <Window.Resources>
    <SolidColorBrush x:Key="Dd.Panel"  Color="#13181D" />
    <SolidColorBrush x:Key="Dd.Border" Color="#20262D" />
    <SolidColorBrush x:Key="Dd.Text"   Color="#EDEDED" />
    <SolidColorBrush x:Key="Dd.Subtle" Color="#9AA4AE" />
    <SolidColorBrush x:Key="Dd.ListBg" Color="#151A20" />
    <SolidColorBrush x:Key="Dd.ListBr" Color="#232A33" />
    <SolidColorBrush x:Key="Dd.Accent" Color="#FF8A00" />
  </Window.Resources>

  <Window.Styles>
    <Style Selector="Button.title">
      <Setter Property="Width" Value="28"/>
      <Setter Property="Height" Value="28"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{StaticResource Dd.Text}"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.title:pointerover">
      <Setter Property="Background" Value="#2E2E2E"/>
    </Style>
    <Style Selector="Button.title:pressed">
      <Setter Property="Background" Value="#3A3A3A"/>
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*" Background="{StaticResource Dd.Panel}">
    <Border Background="{StaticResource Dd.Panel}" BorderBrush="{StaticResource Dd.Border}" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="*,Auto" Height="36">
        <StackPanel Orientation="Horizontal" Spacing="10" Margin="12,0" VerticalAlignment="Center">
          <TextBlock x:Name="TitleText" Text="Config" VerticalAlignment="Center" FontWeight="SemiBold"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,6,0" Spacing="6">
          <Button Classes="title" Click="OnCloseClicked" ToolTip.Tip="Close">
            <Grid Width="12" Height="12">
              <Path Data="M1,1 L11,11" Stroke="White" StrokeThickness="1.7" StrokeLineCap="Round"/>
              <Path Data="M11,1 L1,11" Stroke="White" StrokeThickness="1.7" StrokeLineCap="Round"/>
            </Grid>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" RowDefinitions="Auto,Auto,*" Margin="12">
      <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="2,0,2,8">
        <StackPanel Orientation="Horizontal" Spacing="10">
          <Border Background="#262B31" CornerRadius="8" Padding="8,2" BorderBrush="#333A43" BorderThickness="1">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="Configs"/>
              <TextBlock Text="•"/>
              <TextBlock x:Name="FilesCountText" Text="0"/>
            </StackPanel>
          </Border>
          <Border Background="#262B31" CornerRadius="8" Padding="8,2" BorderBrush="#333A43" BorderThickness="1">
            <StackPanel Spacing="4">
              <TextBlock x:Name="HintText"  Foreground="{StaticResource Dd.Subtle}" FontSize="12" Text="Select a config to edit"/>
              <TextBlock x:Name="HintText2" Foreground="{StaticResource Dd.Subtle}" FontSize="12" Text="ESC closes this window"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>

      <Border Grid.Row="1" Height="1" Background="{StaticResource Dd.ListBr}" Opacity="0.7"/>

      <Grid Grid.Row="2" x:Name="MainSplit" ColumnDefinitions="*,0">
        <Border x:Name="LeftPanel" Grid.Column="0" Grid.ColumnSpan="2"
                Background="{StaticResource Dd.ListBg}" BorderBrush="{StaticResource Dd.ListBr}" BorderThickness="1"
                CornerRadius="10" Margin="0" MinWidth="520" MaxHeight="640">
          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <ListBox x:Name="FilesList" SelectionMode="Single" SelectionChanged="OnSelectionChanged"/>
          </ScrollViewer>
        </Border>

        <Border x:Name="EditorPanel" Grid.Column="1" Background="{StaticResource Dd.ListBg}" BorderBrush="{StaticResource Dd.ListBr}"
                BorderThickness="1" CornerRadius="10" Margin="0" MinWidth="560" IsVisible="False">
          <Grid RowDefinitions="Auto,*">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto" Margin="10,10,10,8">
              <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Editing:"/>
                <TextBlock x:Name="EditorFileName" FontWeight="SemiBold"/>
                <TextBlock x:Name="DirtyDot" Text="• Modified" Foreground="{StaticResource Dd.Accent}" IsVisible="False"/>
              </StackPanel>
              <Button Grid.Column="1" x:Name="SaveBtn"  Content="Save"          Click="OnSaveClicked"  IsEnabled="False" Margin="8,0,0,0"/>
              <Button Grid.Column="2" x:Name="ResetBtn" Content="Reset Changes" Click="OnResetClicked" IsEnabled="False" Margin="8,0,0,0"/>
              <Button Grid.Column="3"                   Content="Close"         Click="OnCloseEditorClicked"           Margin="8,0,0,0"/>
            </Grid>

            <ScrollViewer Grid.Row="1">
            <ae:TextEditor x:Name="EditorText" Margin="8" ShowLineNumbers="True" FontFamily="Consolas, Menlo, Monaco, Courier New"
                           FontSize="14" WordWrap="False" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                           Background="#0F1317" Foreground="#EDEDED" TextChanged="OnEditorTextChanged"/>
            </ScrollViewer>
          </Grid>
        </Border>
      </Grid>
    </Grid>
  </Grid>
</Window>