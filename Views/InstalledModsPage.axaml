<UserControl
    x:Class="DragonDen.ModManager.Views.InstalledModsPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:svc="clr-namespace:DragonDen.ModManager.Services"
    xmlns:global="clr-namespace:"
    mc:Ignorable="d"
    d:DesignWidth="1280" d:DesignHeight="800"
    Focusable="True">

    <UserControl.Resources>
        <svc:StringHasTextConverter x:Key="StringHasTextConverter" />
        <svc:VersionChangeEnabledConverter x:Key="VersionDiffEnabled" />
        <svc:VersionLabelConverter x:Key="VersionLabelConverter" />

        <SolidColorBrush x:Key="Dd.Background" Color="#0F1317" />
        <SolidColorBrush x:Key="Dd.Panel" Color="#12161A" />
        <SolidColorBrush x:Key="Dd.Card" Color="#1B1F24" />
        <SolidColorBrush x:Key="Dd.Card.Hover" Color="#21262C" />
        <SolidColorBrush x:Key="Dd.Border" Color="#2A2A2A" />
        <SolidColorBrush x:Key="Dd.Subtle" Color="#99FFFFFF" />
        <SolidColorBrush x:Key="Dd.Text" Color="#FF8A00" />

        <SolidColorBrush x:Key="Dd.Orange" Color="#FF8A00" />
        <SolidColorBrush x:Key="Dd.Orange.Hover" Color="#FFA333" />

        <SolidColorBrush x:Key="Dd.Green" Color="#1faa33" />
        <SolidColorBrush x:Key="Dd.Green.Hover" Color="#2ad643" />

        <SolidColorBrush x:Key="Dd.Red" Color="#d40404" />
        <SolidColorBrush x:Key="Dd.Red.Hover" Color="#fc2626" />
        
        <SolidColorBrush x:Key="Dd.Black" Color="#111111" />
        <SolidColorBrush x:Key="Dd.Black.Hover" Color="#222222" />

        <SolidColorBrush x:Key="Dd.Btn" Color="#2A2F36" />
        <SolidColorBrush x:Key="Dd.Btn.Hover" Color="#FF8A00" />
        <SolidColorBrush x:Key="Dd.Btn.Fg" Color="#EDEDED" />
        <SolidColorBrush x:Key="Dd.Btn.HoverFg" Color="#111111" />

        <LinearGradientBrush x:Key="Dd.SptBadge" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#fc2626" />
            <GradientStop Offset="1" Color="#d40404" />
        </LinearGradientBrush>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{StaticResource Dd.Card}" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="5" />
            <Setter Property="BorderBrush" Value="{StaticResource Dd.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MinHeight" Value="180" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>
        <Style Selector="Border.card:pointerover">
            <Setter Property="Background" Value="{StaticResource Dd.Card.Hover}" />
        </Style>

        <Style Selector="Border.pill">
            <Setter Property="Background" Value="#262626" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="6,1" />
            <Setter Property="MinHeight" Value="20" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="{StaticResource Dd.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <Style Selector="Button.owner-pill">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="4,1" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MinHeight" Value="20" />
            <Setter Property="FontWeight" Value="DemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="{StaticResource Dd.Orange}" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.owner-pill:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource Dd.Orange.Hover}" />
            <Setter Property="FontWeight" Value="DemiBold"/>
        </Style>

        <Style Selector="Button.btn">
            <Setter Property="Background" Value="{StaticResource Dd.Btn}" />
            <Setter Property="Foreground" Value="{StaticResource Dd.Btn.Fg}" />
            <Setter Property="BorderBrush" Value="{StaticResource Dd.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="MinWidth" Value="84" />
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.btn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource Dd.Btn.Hover}" />
            <Setter Property="Foreground" Value="{StaticResource Dd.Btn.HoverFg}" />
        </Style>
        <Style Selector="Button.btn-success">
            <Setter Property="Background" Value="{StaticResource Dd.Green}" />
            <Setter Property="Foreground" Value="#0C1116" />
        </Style>
        <Style Selector="Button.btn-updateall">
            <Setter Property="Background" Value="{StaticResource Dd.Green}" />
            <Setter Property="Foreground" Value="#0C1116" />
            <Setter Property="FontWeight" Value="DemiBold"/>
        </Style>
        <Style Selector="Button.btn-success:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource Dd.Green.Hover}" />
        </Style>
        <Style Selector="Button.btn-danger">
            <Setter Property="Background" Value="{StaticResource Dd.Red}" />
            <Setter Property="Foreground" Value="#0C1116" />
            <Setter Property="FontWeight" Value="DemiBold"/>
        </Style>
        <Style Selector="Button.btn-danger:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource Dd.Red.Hover}" />
        </Style>
        <Style Selector="Button.btn-neutral">
            <Setter Property="Background" Value="{StaticResource Dd.Btn}" />
            <Setter Property="Foreground" Value="{StaticResource Dd.Btn.Fg}" />
        </Style>
        
        <Style Selector="TextBlock.h2">
            <Setter Property="FontSize" Value="25" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource Dd.Text}" />
        </Style>

        <Style Selector="Button.mod-title">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinHeight" Value="0" />
        </Style>
        <Style Selector="Button.mod-title /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Button.mod-title:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Foreground" Value="#FF8A00" />
        </Style>

        <Style Selector="Button.guid-pill">
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="#262A30" />
            <Setter Property="Foreground" Value="#B7BDC7" />
            <Setter Property="BorderBrush" Value="{StaticResource Dd.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
        <Style Selector="Button.guid-pill:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#262A30" />
            <Setter Property="Foreground" Value="#B7BDC7" />
        </Style>

        <Style Selector="#ModsList ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,2" />
        </Style>
        <Style Selector="#ModsList ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="#ModsList ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="#ModsList ListBoxItem:focus /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
    </UserControl.Styles>

    <Grid Background="{StaticResource Dd.Background}">
        <Grid x:Name="MainContent" RowDefinitions="Auto,Auto,*">
            <Border Background="{StaticResource Dd.Panel}" Padding="10" Grid.Row="0"
                    BorderBrush="{StaticResource Dd.Border}" BorderThickness="0,0,0,1">
                <DockPanel LastChildFill="True">
                    <StackPanel Orientation="Horizontal" Spacing="8" DockPanel.Dock="Left">
                        <Button x:Name="RefreshBtn" Content="Refresh Mods" Classes="btn btn-neutral" />
                        <Button x:Name="CheckUpdatesBtn" Content="Look for updates" Classes="btn btn-neutral" />
                        <Button x:Name="UpdateAllBtn" Content="Update all mods" Classes="btn btn-updateall" />
                        <Button x:Name="OpenClientBtn" Content="Open Client Mods" Classes="btn btn-neutral" />
                        <Button x:Name="OpenServerBtn" Content="Open Server Mods" Classes="btn btn-neutral" />
                        <Button x:Name="UninstallAllBtn" Content="Uninstall All Mods" Classes="btn btn-danger" />
                    </StackPanel>

                    <TextBlock x:Name="StatusText"
                               Margin="10,0,0,0"
                               DockPanel.Dock="Right"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource Dd.Subtle}" />
                </DockPanel>
            </Border>

            <Border Background="{StaticResource Dd.Panel}" Padding="10" Grid.Row="1"
                    BorderBrush="{StaticResource Dd.Border}" BorderThickness="0,0,0,1">
                <DockPanel LastChildFill="True">
                    <StackPanel Orientation="Horizontal" Spacing="10" DockPanel.Dock="Left">
                        <TextBox x:Name="SearchBox" Width="440" Watermark="Search mods or type @Author…" />
                        <Button x:Name="ClearBtn" Content="Clear" Classes="btn btn-neutral" />
                        <ComboBox x:Name="SortBox" Width="200" SelectedIndex="0" Margin="0,0,0,0">
                            <ComboBoxItem Content="Alphabetical (A→Z)" Tag="alpha" />
                            <ComboBoxItem Content="Newest installed" Tag="installed_desc" />
                            <ComboBoxItem Content="Oldest installed" Tag="installed_asc" />
                        </ComboBox>
                        <CheckBox x:Name="UpdatesFirstChk" Content="Updates first" IsChecked="True" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <ScrollViewer x:Name="ModsScroll" Grid.Row="2" HorizontalScrollBarVisibility="Disabled">
                <ListBox x:Name="ModsList"
                         Background="Transparent"
                         BorderBrush="Transparent">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel HorizontalAlignment="Center" Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>

                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="global:InstalledModRow">
                            <Border Classes="card" MinWidth="600" MaxWidth="600">
                                <Grid ColumnDefinitions="170,*" RowDefinitions="Auto,*,Auto">
                                    <Border Grid.Row="0" Grid.Column="0"
                                            Width="165" Height="165"
                                            CornerRadius="12" Margin="0"
                                            Background="#101418" BorderBrush="{StaticResource Dd.Border}" BorderThickness="1"
                                            ClipToBounds="True">
                                        <Grid>
                                            <svc:WebImage x:Name="Thumb" Url="{Binding Thumbnail}" Stretch="UniformToFill" />
                                        </Grid>

                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8" Padding="8,2"
                                            CornerRadius="10" Background="{StaticResource Dd.SptBadge}" IsVisible="{Binding IsOutdated}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="Outdated" FontWeight="Bold" Foreground="{StaticResource Dd.Black}"
                                                       IsVisible="{Binding IsOutdated}" />
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="6" ClipToBounds="True">
                                        <Button Classes="mod-title"
                                                IsEnabled="{Binding HasPage}"
                                                Tag="{Binding DetailUrl}"
                                                Click="OnOpenPageFromTitle">
                                            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold"
                                                       TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis" />
                                        </Button>

                                        <Button Classes="guid-pill"
                                                IsVisible="{Binding Guid, Converter={StaticResource StringHasTextConverter}}"
                                                Tag="{Binding Guid}"
                                                ToolTip.Tip="Click to copy"
                                                Click="OnCopyGuid">
                                            <TextBlock Text="{Binding Guid, StringFormat=(\{0\})}" />
                                        </Button>

                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Border Classes="pill" Padding="10,2,10,2" IsVisible="{Binding HasCategory}">
                                                <TextBlock Text="{Binding Category}" />
                                            </Border>

                                            <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                                          VerticalScrollBarVisibility="Disabled"
                                                          PointerWheelChanged="OnAuthorsWheel"
                                                          ClipToBounds="True">
                                                <ItemsControl ItemsSource="{Binding Authors}" IsVisible="{Binding HasAuthors}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" Spacing="6" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button Classes="owner-pill" Padding="10,2,10,2" Content="{Binding .}" Tag="{Binding .}" Click="OnAuthorClick" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </StackPanel>

                                        <Border Classes="pill" Padding="10,2,10,2" HorizontalAlignment="Left">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="Installed" />
                                                <TextBlock Text="{Binding InstalledVersion}" />
                                                <TextBlock Text="•" />
                                                <TextBlock Text="Files" />
                                                <TextBlock Text="{Binding FileCount}" />
                                            </StackPanel>
                                        </Border>

                                        <Border Classes="pill" Padding="10,2,10,2" HorizontalAlignment="Left" IsVisible="{Binding InstalledAtText, Converter={StaticResource StringHasTextConverter}}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="Installed" />
                                                <TextBlock Text="{Binding InstalledAtText}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Classes="pill" Padding="10,2,10,2" HorizontalAlignment="Left" IsVisible="{Binding LatestPublishedText, Converter={StaticResource StringHasTextConverter}}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="Latest published" />
                                                <TextBlock Text="{Binding LatestPublishedText}" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Grid.Column="0"
                                                Spacing="8" Margin="0,0,0,0" VerticalAlignment="Bottom">
                                        <WrapPanel Orientation="Horizontal" Margin="2,5,0,0">
                                            <ComboBox x:Name="VerBox" Width="297"
                                                      ItemsSource="{Binding Versions}"
                                                      SelectedIndex="0"
                                                      AttachedToVisualTree="OnVersionBoxAttached">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding ., Converter={StaticResource VersionLabelConverter}}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <Button Content="Change Version" Margin="8,0,0,0" Classes="btn"
                                                    Tag="{Binding ElementName=VerBox, Path=SelectedItem}"
                                                    Click="OnChangeVersion">
                                                <Button.IsEnabled>
                                                    <MultiBinding Converter="{StaticResource VersionDiffEnabled}">
                                                        <Binding Path="InstalledVersion" />
                                                        <Binding ElementName="VerBox" Path="SelectedItem" />
                                                    </MultiBinding>
                                                </Button.IsEnabled>
                                            </Button>
                                        </WrapPanel>
                                        <WrapPanel Orientation="Horizontal" Margin="2,5,0,0">

                                            <Button Content="Update" Margin="8,0,0,0" Classes="btn btn-success" IsEnabled="{Binding CanUpdate}"
                                                    Tag="{Binding .}" />
                                            <Button Content="Uninstall" Margin="8,0,0,0" Classes="btn btn-danger"
                                                    Tag="{Binding .}" />
                                            <Button Content="List Files" Margin="8,0,0,0" Classes="btn btn-neutral"
                                                    Tag="{Binding .}" />

                                            <ItemsControl ItemsSource="{Binding SourceButtons}" IsVisible="{Binding HasSources}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="5" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Classes="btn btn-neutral"
                                                                Margin="5,0,0,0"
                                                                Content="{Binding Label}"
                                                                Tag="{Binding Url}"
                                                                Click="OnOpenSource" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </WrapPanel>
                                    </StackPanel>
                                </Grid>

                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Open Mod Page" Tag="{Binding DetailUrl}" Click="OnOpenPageFromContext" />
                                        <MenuItem Header="Copy Page URL" Tag="{Binding DetailUrl}" Click="OnCopyLink" />
                                        <MenuItem Header="Copy GUID" Tag="{Binding Guid}" Click="OnCopyGuid" />
                                        <MenuItem Header="Open Thumbnail" Tag="{Binding Thumbnail}" Click="OnOpenThumb" />
                                    </ContextMenu>
                                </Border.ContextMenu>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
            
            <StackPanel Grid.Row="2" x:Name="EmptyState"
                        Spacing="8"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        IsVisible="False">
                <TextBlock Classes="h2"
                           Text="No mods found." 
                           HorizontalAlignment="Center"/>
                <TextBlock Opacity="0.85"
                           Text="Install something from Browse Mods, or click 'Refresh Mods' to scan your SPT folder."
                           TextAlignment="Center"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>